# Required: your OpenAI API key
OPENAI_API_KEY=

# To use a different provider, swap the import in lib/agent.ts:
#   import { anthropic } from "@ai-sdk/anthropic";   → openai("gpt-4o-mini") → anthropic("claude-3-5-haiku-20241022")
#   import { google }    from "@ai-sdk/google";       → google("gemini-2.0-flash")
# Then update this env var accordingly (e.g. ANTHROPIC_API_KEY=, GOOGLE_GENERATIVE_AI_API_KEY=).
